{$DOMAIN} {
    encode gzip zstd

    @backend_api path /api /api/*
    handle_path @backend_api {
        reverse_proxy backend:8000
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /health {
        reverse_proxy backend:8000
    }

    handle /ready {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:8501
    }
}
